# =============================================================================
# CORE APPLICATION
# =============================================================================
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
CBT_SITE_NAME="CBT Pro"
LANGUAGE_CODE=id
TIME_ZONE=Asia/Jakarta
USE_TZ=True

# Optional overrides.
# CUSTOM_ERROR_PAGES=True
# SERVE_STATIC_WITH_DJANGO=True
# DEMO_MODE=False

# =============================================================================
# HOSTS, PROXY, AND HTTPS
# =============================================================================
ALLOWED_HOSTS=127.0.0.1,localhost,cbt.example.com
CSRF_TRUSTED_ORIGINS=https://cbt.example.com
# Set True hanya jika aplikasi berada di balik HTTPS proxy seperti Nginx/Caddy/Cloudflare.
HTTPS_ENABLED=False
USE_X_FORWARDED_HOST=False
SECURE_PROXY_SSL_HEADER_ENABLED=False

# =============================================================================
# MARKETING AND BRANDING
# =============================================================================
MARKETING_ENABLED=True
MARKETING_PRODUCT_NAME="CBT Pro"
# Optional explicit marketing site URL. If omitted, settings fallback is used.
# MARKETING_SITE_URL=https://cbtpro.web.id
MARKETING_CONTACT_EMAIL="halo@cbtpro.web.id"
MARKETING_WHATSAPP_NUMBER="628xxxxxxxxxx"
MARKETING_TELEGRAM_URL="https://t.me/cbtprowebid"
MARKETING_OPERATING_HOURS="Senin - Sabtu, 08.00 - 17.00 WIB"
MARKETING_LIST_PRICE=999999
MARKETING_DISCOUNT_PERCENT=80

# =============================================================================
# DEMO MODE
# =============================================================================
DEMO=False
DEMO_TEACHER_USERNAME=olivia.carter
DEMO_TEACHER_EMAIL=olivia.carter@mail.com
DEMO_TEACHER_PASSWORD=teacher123
DEMO_STUDENT_USERNAME=ethan.walker
DEMO_STUDENT_EMAIL=ethan.walker@mail.com
DEMO_STUDENT_PASSWORD=student123

# =============================================================================
# DATABASE
# =============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=cbt_database
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_OPTIONS={"charset":"utf8mb4"}
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECKS=True

# =============================================================================
# EMAIL
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL="CBT System <noreply@cbt.com>"

# =============================================================================
# REDIS AND CELERY
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=Asia/Jakarta
CELERY_TASK_SYNC_FALLBACK=True

# =============================================================================
# STATIC AND MEDIA
# =============================================================================
STATIC_URL=/static/
STATIC_ROOT=staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=media/

# =============================================================================
# FRONTEND INTEGRATIONS
# =============================================================================
# Isi jika ingin memakai Tiny Cloud, kosongkan untuk fallback CDN tanpa API key.
TINYMCE_API_KEY=

# =============================================================================
# IMPORT LIMITS
# =============================================================================
USER_IMPORT_MAX_ROWS=5000
USER_IMPORT_CHUNK_SIZE=250
QUESTION_IMPORT_MAX_ROWS=10000
QUESTION_IMPORT_CHUNK_SIZE=200

# =============================================================================
# SECURITY
# =============================================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
X_FRAME_OPTIONS=DENY

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# PROCTORING
# =============================================================================
ENABLE_SCREENSHOT_PROCTORING=False
SCREENSHOT_INTERVAL_SECONDS=300
MAX_VIOLATIONS_ALLOWED=3
