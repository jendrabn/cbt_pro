# =============================================================================
# CBT SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# GENERAL APP SETTINGS
# =============================================================================
CBT_SITE_NAME="Sistem CBT"
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,cbt.example.com
CSRF_TRUSTED_ORIGINS=https://cbt.example.com
TIME_ZONE=Asia/Jakarta
LANGUAGE_CODE=id
USE_TZ=True

# Reverse proxy / HTTPS
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER_ENABLED=True

# =============================================================================
# DATABASE CONFIGURATION (MySQL)
# =============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=cbt_database
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_OPTIONS={"charset":"utf8mb4"}

# Database Pool Settings (Optional)
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECKS=True

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL="CBT System <noreply@cbt.com>"

# =============================================================================
# REDIS & CELERY CONFIGURATION (Optional)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=Asia/Jakarta
CELERY_TASK_SYNC_FALLBACK=True

# =============================================================================
# MEDIA & STATIC FILES
# =============================================================================
MEDIA_URL=/media/
MEDIA_ROOT=media/
STATIC_URL=/static/
STATIC_ROOT=staticfiles/

# =============================================================================
# FRONTEND INTEGRATIONS
# =============================================================================
# Isi jika ingin memakai Tiny Cloud, kosongkan untuk fallback CDN tanpa API key.
TINYMCE_API_KEY=

# =============================================================================
# IMPORT LIMITS
# =============================================================================
USER_IMPORT_MAX_ROWS=5000
USER_IMPORT_CHUNK_SIZE=250
QUESTION_IMPORT_MAX_ROWS=10000
QUESTION_IMPORT_CHUNK_SIZE=200

# =============================================================================
# SECURITY SETTINGS (Production)
# =============================================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
X_FRAME_OPTIONS=DENY

# =============================================================================
# LOGGING LEVEL
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# PROCTORING SETTINGS
# =============================================================================
ENABLE_SCREENSHOT_PROCTORING=False
SCREENSHOT_INTERVAL_SECONDS=300
MAX_VIOLATIONS_ALLOWED=3
